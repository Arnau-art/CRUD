<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20" style="-fx-background-color: #1a1a1a; -fx-padding: 30;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.crud.Controller.DetalleController">

    <Label fx:id="lblTitulo" style="-fx-font-size: 36; -fx-text-fill: #f1c40f; -fx-font-weight: bold;" text="CARGANDO..." />

    <HBox alignment="CENTER" spacing="40" VBox.vgrow="ALWAYS">
        <VBox alignment="CENTER" style="-fx-border-color: #f1c40f; -fx-border-width: 2; -fx-background-color: #2c3e50;">
            <VBox alignment="CENTER" style="-fx-border-color: red; -fx-border-width: 2; -fx-background-color: white;">
                <ImageView fx:id="imgClase"
                           fitHeight="300.0"
                           fitWidth="300.0"
                           preserveRatio="true"
                           smooth="true"
                           cache="true" />
            </VBox>
        </VBox>

        <VBox spacing="15" prefWidth="400">
            <Label text="Descripción Detallada" style="-fx-text-fill: #f1c40f; -fx-font-size: 18; -fx-font-weight: bold;" />
            <TextArea fx:id="txtDescripcionLarga" editable="false" wrapText="true"
                      style="-fx-control-inner-background: #2c3e50; -fx-text-fill: white; -fx-font-size: 16;"
                      prefHeight="300.0" />
        </VBox>
    </HBox>

    <Button onAction="#volverALista" text="Volver a la Lista"
            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 16; -fx-padding: 10 20; -fx-cursor: hand;" />

</VBox>