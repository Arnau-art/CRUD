<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" alignment="CENTER" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.crud.Controller.ClasesController"
      style="-fx-padding: 30; -fx-background-color: #2c3e50;">

    <Label text="Lista de Clases" style="-fx-font-size: 24; -fx-text-fill: white;"/>

    <TableView fx:id="tablaEspecs" onMouseClicked="#onFilaSeleccionada" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colClase" text="CLASE" />
            <TableColumn fx:id="colEspec" text="ESPECIALIZACIÓN" />
            <TableColumn fx:id="colDesc" text="DESCRIPCIÓN" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>

    </TableView>

    <Button text="Volver al Menú" onAction="#volverMenu" />

</VBox>